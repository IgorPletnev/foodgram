# ⚠️ Это шаблон. Скопируйте в .env и замените значения на свои.
# Для продакшена используйте реальные данные из infra/.env на сервере.

# PostgreSQL
POSTGRES_DB=foodgram
POSTGRES_USER=foodgram_user
POSTGRES_PASSWORD=your_strong_password_here
DB_HOST=db
DB_PORT=5432

# Django
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost 127.0.0.1 81.26.184.67 julik.ddns.net
CSRF_TRUSTED_ORIGINS=http://localhost:8000 http://81.26.184.67 https://julik.ddns.net

# Frontend URL 
FRONTEND_URL=https://julik.ddns.net